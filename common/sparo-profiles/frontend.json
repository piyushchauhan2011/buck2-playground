/**
 * OWNER:   Frontend / JS team
 * PURPOSE: Use this profile when working on the TypeScript/Express API or any
 *          JavaScript package.  Includes the shared common library that the JS
 *          API depends on.
 *
 * NOTE: This repo uses Buck2 (not Rush), so "selections" is empty.
 *       Dependency resolution is handled by `buck2 uquery rdeps()` in CI.
 */
{
  "$schema": "https://tiktok.github.io/sparo/schemas/sparo-profile.schema.json",
  "selections": [],
  "includeFolders": [
    "domains/api/js",
    "domains/api",
    "libs/common",
    "toolchains",
    "scripts"
  ]
}
