/**
 * OWNER:   Backend team
 * PURPOSE: Use this profile when working on the REST API (Python), backend
 *          services, or anything that touches the shared common library.
 *
 * NOTE: This repo uses Buck2 (not Rush), so "selections" is empty.
 *       Dependency resolution is handled by `buck2 uquery rdeps()` in CI.
 *       Add directories below under "includeFolders" when the team's scope
 *       grows.
 */
{
  "$schema": "https://tiktok.github.io/sparo/schemas/sparo-profile.schema.json",
  "selections": [],
  "includeFolders": [
    "domains/api",
    "domains/backend",
    "libs/common",
    "toolchains",
    "scripts"
  ]
}
