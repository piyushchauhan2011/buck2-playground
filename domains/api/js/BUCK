load("//build_defs:ts_project.bzl", "ts_project")

# domains/api/js - TypeScript + Express 5 service
#
# ts_project() generates six targets from one call:
#   api_js_lint, api_js_fmt, api_js_typecheck,
#   api_js_build, api_js_vitest, api_js_sast
#
# build_deps = ["//libs/common:common_build"] ensures libs/common/dist/
# exists before tsc -p tsconfig.build.json runs here (composite project
# references require the upstream dist/ to be present).
#
# srcs use glob() for sparse-checkout compatibility: glob() returns []
# when source files are absent (uquery time) and the real list at build time.

ts_project(
    name = "api_js",
    package_dir = "domains/api/js",
    srcs = glob([
        "src/*.ts",
        "test/*.ts",
        "package.json",
        "tsconfig*.json",
        "eslint.config.js",
        ".prettierrc.json",
    ]),
    build_deps = ["//libs/common:common_build"],
)

# Cross-package graph-edge target.
# The $(location //libs/common:common) reference makes uquery rdeps()
# aware of the edge so that changes to libs/common trigger api_js targets.
genrule(
    name = "api_js",
    out = "api_js.js",
    srcs = glob(["src/*.ts"]),
    cmd = "common=$(location //libs/common:common); repo=\\$(git rev-parse --show-toplevel); cp \"$repo/domains/api/js/src/server.ts\" \"$OUT\"",
)
