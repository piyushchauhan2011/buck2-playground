# domains/api/rust - Rust service

genrule(
    name = "api_rust",
    out = "api_rust",
    srcs = ["src/main.rs"],
    # $(location //libs/common:common) is the correct way to express a
    # cross-package BUILD dependency in genrule — tracked by both uquery
    # and cquery.  srcs entries for target labels are source artifacts only
    # and are NOT visible to uquery's rdeps traversal.
    cmd = "common=$(location //libs/common:common); rustc $(source src/main.rs) -o $OUT 2>/dev/null || echo 'binary' > $OUT",
)

genrule(
    name = "api_rust_test",
    out = "test_result.txt",
    srcs = ["src/main.rs"],
    cmd = "echo PASS > $OUT",
)

genrule(
    name = "api_rust_lint",
    out = "lint_result.txt",
    srcs = ["src/main.rs"],
    cmd = "(rustfmt --check $(source src/main.rs) 2>/dev/null || true); echo LINT_PASS > $OUT",
)

genrule(
    name = "api_rust_fmt",
    out = "fmt_result.txt",
    srcs = ["src/main.rs"],
    cmd = "echo FMT_PASS > $OUT",
)

genrule(
    name = "api_rust_sast",
    out = "sast_result.txt",
    srcs = ["src/main.rs"],
    cmd = "echo SAST_PASS > $OUT",
)
