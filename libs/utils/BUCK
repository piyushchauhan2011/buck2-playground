load("//build_defs:ts_project.bzl", "ts_project")

# libs/utils - base utility library consumed by libs/common
#
# ts_project() generates: utils_lint, utils_fmt, utils_typecheck,
#   utils_build, utils_vitest, utils_sast.
#
# No build_deps: utils is the bottom of the dependency chain.
#
# srcs use glob() for sparse-checkout compatibility.

ts_project(
    name = "utils",
    package_dir = "libs/utils",
    srcs = glob([
        "src/*.ts",
        "test/*.ts",
        "package.json",
        "tsconfig*.json",
    ]),
    visibility = ["//libs/..."],
)

# Graph-edge target consumed by libs/common:common via
#   $(location //libs/utils:utils)
genrule(
    name = "utils",
    out = "utils.txt",
    srcs = glob(["src/*.ts"]),
    cmd = "printf 'base utils lib\\nversion: 1.0.0\\n' > $OUT",
    visibility = ["//libs/..."],
)
