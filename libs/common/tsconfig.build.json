{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "references": [
    { "path": "../utils/tsconfig.build.json" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["test/**", "dist", "node_modules"]
}
