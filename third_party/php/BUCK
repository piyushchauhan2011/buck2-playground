# Hermetic PHP and Composer for Buck2 monorepo.
#
# PHP: static-php-cli binaries (Linux/macOS). Referenced as //third_party/php:php_hermetic
#      so genrules in root cell avoid cross-cell path issues.
# Composer: composer.phar for hermetic composer install.

load("@prelude//:prelude.bzl", "native")

# Pre-built PHP 8.2.18 CLI from static-php.dev (common build: openssl, curl, etc.).
# Satisfies composer ^8.2; used for hermetic builds in CI.
# https://dl.static-php.dev/static-php-cli/common/
native.http_archive(
    name = "php_archive",
    urls = [select({
        "DEFAULT": "https://dl.static-php.dev/static-php-cli/common/php-8.2.18-cli-linux-x86_64.tar.gz",
        "prelude//os:linux": select({
            "prelude//cpu:arm64": "https://dl.static-php.dev/static-php-cli/common/php-8.2.18-cli-linux-aarch64.tar.gz",
            "prelude//cpu:x86_64": "https://dl.static-php.dev/static-php-cli/common/php-8.2.18-cli-linux-x86_64.tar.gz",
        }),
        "prelude//os:macos": select({
            "prelude//cpu:arm64": "https://dl.static-php.dev/static-php-cli/common/php-8.2.18-cli-macos-aarch64.tar.gz",
            "prelude//cpu:x86_64": "https://dl.static-php.dev/static-php-cli/common/php-8.2.18-cli-macos-x86_64.tar.gz",
        }),
    })],
    sha256 = select({
        "DEFAULT": "c381bae91b0b8241ad1121a2335331a5924bc52cf6be6357e1f59084e0221711",
        "prelude//os:linux": select({
            "prelude//cpu:arm64": "489ed15be5aafb6b8cfd478c535dfcd39c6ecacc4b66935b474f3ffc115e32ba",
            "prelude//cpu:x86_64": "c381bae91b0b8241ad1121a2335331a5924bc52cf6be6357e1f59084e0221711",
        }),
        "prelude//os:macos": select({
            "prelude//cpu:arm64": "9f5c89520ad162dc35f85dbfce7a871cb5e21844471ff43ebbe93674a093112c",
            "prelude//cpu:x86_64": "4e9c645ee87461450fe5dfa88622854562b7b1c4ecf61380b73751f1aa8656f5",
        }),
    }),
    strip_prefix = "",
    sub_targets = {
        "php": ["php"],
    },
)

native.command_alias(
    name = "php_hermetic",
    exe = ":php_archive[php]",
    visibility = ["PUBLIC"],
)

# Composer 2.9.5 - https://getcomposer.org/download/
remote_file(
    name = "composer_phar",
    url = "https://getcomposer.org/download/2.9.5/composer.phar",
    sha256 = "c86ce603fe836bf0861a38c93ac566c8f1e69ac44b2445d9b7a6a17ea2e9972a",
    out = "composer.phar",
    visibility = ["PUBLIC"],
)
