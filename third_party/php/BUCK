# Hermetic PHP and Composer for Buck2 monorepo.
#
# PHP: static-php-cli binaries (Linux/macOS). Referenced as //third_party/php:php_hermetic
#      so genrules in root cell avoid cross-cell path issues.
# Composer: composer.phar for hermetic composer install.

load("@prelude//:prelude.bzl", "native")

# Pre-built PHP 8.1.31 CLI from static-php.dev (minimal - no openssl).
# For projects requiring PHP 8.2+ or Composer network access, use system PHP
# (use_hermetic=False) or switch to common/ build (has openssl).
# https://dl.static-php.dev/static-php-cli/minimal/
native.http_archive(
    name = "php_archive",
    urls = [select({
        "DEFAULT": "https://dl.static-php.dev/static-php-cli/minimal/php-8.1.31-cli-linux-x86_64.tar.gz",
        "prelude//os:linux": select({
            "prelude//cpu:arm64": "https://dl.static-php.dev/static-php-cli/minimal/php-8.1.31-cli-linux-aarch64.tar.gz",
            "prelude//cpu:x86_64": "https://dl.static-php.dev/static-php-cli/minimal/php-8.1.31-cli-linux-x86_64.tar.gz",
        }),
        "prelude//os:macos": select({
            "prelude//cpu:arm64": "https://dl.static-php.dev/static-php-cli/minimal/php-8.1.31-cli-macos-aarch64.tar.gz",
            "prelude//cpu:x86_64": "https://dl.static-php.dev/static-php-cli/minimal/php-8.1.31-cli-macos-x86_64.tar.gz",
        }),
    })],
    sha256 = select({
        "DEFAULT": "727f24c5a1ee716f05f880609fc4aeea08055e6fc09e71a6fe54d1b44d5171aa",
        "prelude//os:linux": select({
            "prelude//cpu:arm64": "c2ef31c44c68e4b7dd40b4cb11f764022e685e479716c6a32232e90308efa9f9",
            "prelude//cpu:x86_64": "727f24c5a1ee716f05f880609fc4aeea08055e6fc09e71a6fe54d1b44d5171aa",
        }),
        "prelude//os:macos": select({
            "prelude//cpu:arm64": "49789df9b8b701ff6b0e6d26e9838480804ea4de1c060303dcff2965016622c4",
            "prelude//cpu:x86_64": "727f24c5a1ee716f05f880609fc4aeea08055e6fc09e71a6fe54d1b44d5171aa",
        }),
    }),
    strip_prefix = "",
    sub_targets = {
        "php": ["php"],
    },
)

native.command_alias(
    name = "php_hermetic",
    exe = ":php_archive[php]",
    visibility = ["PUBLIC"],
)

# Composer 2.9.5 - https://getcomposer.org/download/
remote_file(
    name = "composer_phar",
    url = "https://getcomposer.org/download/2.9.5/composer.phar",
    sha256 = "c86ce603fe836bf0861a38c93ac566c8f1e69ac44b2445d9b7a6a17ea2e9972a",
    out = "composer.phar",
    visibility = ["PUBLIC"],
)
