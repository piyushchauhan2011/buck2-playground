# Third-party Python dependencies — hermetic wheel downloads.
#
# Every dependency is declared as:
#   remote_file  — downloads the .whl from PyPI (sha256-verified)
#   prebuilt_python_library  — wraps the wheel for python_library/python_binary deps
#
# Buck does NOT infer pip dependency graphs, so deps must be spelled out.
# To update a package: bump the version, update the URL and sha256, and
# adjust the deps list if the package gained/dropped dependencies.
#
# PLATFORM-SPECIFIC PACKAGES
# Packages with compiled extensions (pydantic-core) need per-platform
# wheels.  We default to manylinux x86_64 for CI compatibility.  See the
# pydantic-core section below for the macOS alternative.

# ── fastapi (ASGI framework) ─────────────────────────────────────────────────

remote_file(
    name = "fastapi_whl",
    url = "https://files.pythonhosted.org/packages/06/ab/a1f7eed031aeb1c406a6e9d45ca04bff401c8a25a30dd0e4fd2caae767c3/fastapi-0.115.0-py3-none-any.whl",
    sha256 = "17ea427674467486e997206a5ab25760f6b09e069f099b96f5b55a32fb6f1631",
    out = "fastapi-0.115.0-py3-none-any.whl",
)

prebuilt_python_library(
    name = "fastapi",
    binary_src = ":fastapi_whl",
    deps = [":starlette", ":pydantic", ":typing-extensions"],
    visibility = ["PUBLIC"],
)

